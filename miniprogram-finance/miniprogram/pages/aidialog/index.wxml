<view class="safe">
  <view class="topbar topbar-chat">
    <view class="back-btn" bindtap="goBack">←</view>
    <view class="chat-brand">
      <text class="chat-brand-icon">🤖</text>
      <text class="chat-brand-text">AI智能股票问答</text>
    </view>
    <text class="pill">Beta</text>
  </view>

  <view class="chat-page">
    <view class="chat-head">
      <input
        class="symbol-input"
        value="{{keyword}}"
        placeholder="输入股票代码/名称，如 300750 或 宁德时代"
        bindinput="onKeywordInput"
        confirm-type="search"
        bindconfirm="analyzeByInput"
      />
      <view class="symbol-btn" bindtap="analyzeByInput">切换股票</view>
    </view>

    <view class="stock-chip">
      <text class="stock-chip-name">{{current.fullName}}</text>
      <text class="stock-chip-price">{{current.price}}</text>
    </view>

    <scroll-view scroll-y class="chat-list" scroll-into-view="{{toViewId}}">
      <view
        wx:for="{{messages}}"
        wx:key="id"
        id="msg-{{item.id}}"
        class="msg-row {{item.role === 'user' ? 'msg-user-row' : 'msg-ai-row'}}"
      >
        <view class="msg-bubble {{item.role === 'user' ? 'msg-user' : 'msg-ai'}}">
          <text class="msg-text">{{item.content}}</text>
        </view>
      </view>
    </scroll-view>

    <view class="chat-footer safe">
      <scroll-view scroll-x class="qa-tags">
        <text class="qa-tag" wx:for="{{quickQuestions}}" wx:key="*this" bindtap="useQuickQuestion" data-q="{{item}}">{{item}}</text>
      </scroll-view>
      <view class="ask-row">
        <input
          class="ask-input"
          value="{{question}}"
          placeholder="问AI：这只股票现在怎么看？"
          bindinput="onQuestionInput"
          confirm-type="send"
          bindconfirm="sendQuestion"
        />
        <view class="ask-btn" bindtap="sendQuestion">发送</view>
      </view>
    </view>
  </view>
</view>

