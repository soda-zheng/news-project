.back-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  border: 2rpx solid #E4E7EC;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  font-size: 32rpx;
  color: #344054;
}

.search-card {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.search-input {
  flex: 1;
  height: 76rpx;
  background: #F8F9FC;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
}

.search-btn {
  width: 120rpx;
  height: 76rpx;
  border-radius: 16rpx;
  background: #2F54EB;
  color: #FFFFFF;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stock-name { font-size: 30rpx; font-weight: 800; }
.stock-price { font-size: 40rpx; font-weight: 900; color: #16A34A; }
.stock-info { margin-top: 8rpx; font-size: 22rpx; }

.chart-box {
  margin-top: 14rpx;
  margin-bottom: 16rpx;
  height: 220rpx;
  border-radius: 16rpx;
  background: #F8F9FC;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}
.chart-inner {
  display: flex;
  align-items: flex-end;
  gap: 10rpx;
  height: 120rpx;
}
.chart-bar {
  width: 18rpx;
  border-radius: 10rpx;
  background: #2F54EB;
  opacity: 0.85;
}
.b1 { height: 44rpx; opacity: 0.35; }
.b2 { height: 68rpx; opacity: 0.55; }
.b3 { height: 96rpx; opacity: 0.75; }
.b4 { height: 78rpx; opacity: 0.6; }
.b5 { height: 110rpx; opacity: 0.9; }
.chart-text { margin-top: 12rpx; font-size: 22rpx; }

.kv {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 2rpx solid #EEF2F6;
}
.kv-last { border-bottom: 0; }
.k { font-size: 22rpx; }
.v { font-size: 24rpx; font-weight: 700; }

.left-blue { border-left: 10rpx solid #2F54EB; }
.left-red { border-left: 10rpx solid #EF4444; }
.left-green { border-left: 10rpx solid #16A34A; }

.line {
  font-size: 24rpx;
  line-height: 38rpx;
  color: #344054;
  margin-bottom: 8rpx;
}

.ask-entry {
  height: 84rpx;
  border-radius: 16rpx;
  background: #E9EEFF;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  margin: 4rpx 0 12rpx;
}

.ask-entry-icon { font-size: 30rpx; }
.ask-entry-text {
  flex: 1;
  margin-left: 10rpx;
  font-size: 26rpx;
  color: #2F54EB;
  font-weight: 700;
}
.ask-entry-arrow { font-size: 34rpx; color: #2F54EB; }

