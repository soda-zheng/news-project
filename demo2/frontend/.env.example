# 线上后端（构建前设置）；不设则默认本机 http://127.0.0.1:5000
# VITE_API_BASE_URL=https://api.example.com

# --- 方式 A：单隧道（只开 cloudflared 指向前端 5173，API 走 Vite 代理）---
# VITE_API_RELATIVE=1

# --- 方式 B：双隧道（前端 5173、后端 5000 各一条 cloudflared）---
# 不要写 VITE_API_RELATIVE=1。把后端隧道输出的 https 填到下面（无尾斜杠）
 VITE_API_BASE_URL=0.0.0.0
