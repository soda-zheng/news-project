# 复制为 .env 后填写（勿提交真实 Key）
LLM_PROVIDER=openai_compat
LLM_USE_LOCAL=0
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus-2025-07-28
LLM_API_KEY=
# 首页新闻是否启用 AI 深度分析（0=关闭，省 token）
HOME_NEWS_AI_ENABLED=0
# 个股分析页是否启用 LLM 研判（0=关闭，省 token）
STOCK_LLM_AI_ENABLED=0
HOT_TOPICS_CACHE_SEC=120
HOT_TOPICS_EM_CACHE_SEC=600
HOT_BOARDS_CACHE_SEC=600
