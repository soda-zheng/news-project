:root, page {
  background: #F3F5F8;
  color: #101828;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", Segoe UI, Roboto, Helvetica, Arial, sans-serif;
}

.safe {
  padding-top: calc(env(safe-area-inset-top) + 8rpx);
  padding-bottom: env(safe-area-inset-bottom);
}

.container {
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.topbar {
  padding: 18rpx 24rpx 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.topbar-left {
  display: flex;
  flex-direction: column;
}

.top-title {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 0.2rpx;
}

.top-sub {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #667085;
}

.pill {
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #2F54EB;
  background: #EEF2FF;
}

.card {
  background: #FFFFFF;
  border-radius: 22rpx;
  padding: 22rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.muted {
  color: #667085;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.btn-primary {
  height: 82rpx;
  border-radius: 999rpx;
  background: #2F54EB;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-ghost {
  margin-top: 12rpx;
  border-radius: 16rpx;
  border: 2rpx solid #D0D5DD;
  color: #344054;
  font-size: 24rpx;
  padding: 18rpx 16rpx;
}

.tag-wrap {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  font-size: 22rpx;
  color: #2F54EB;
  background: #EEF2FF;
  border-radius: 999rpx;
  padding: 10rpx 18rpx;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}

.divider {
  height: 2rpx;
  background: #EEF2F6;
  margin: 12rpx 0;
}

.disclaimer {
  text-align: center;
  font-size: 20rpx;
  color: #98A2B3;
  padding: 8rpx 10rpx 18rpx;
}

