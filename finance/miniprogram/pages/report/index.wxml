<view class="safe">
  <view class="topbar">
    <view class="topbar-left">
      <text class="top-title">财报分析</text>
      <text class="top-sub">结构化解读 · 简约呈现</text>
    </view>
    <text class="pill">演示版</text>
  </view>

  <view class="container">
    <view class="card">
      <view class="section-title">你将获得什么</view>
      <view class="line" wx:for="{{reportTips}}" wx:key="*this">- {{item}}</view>
      <view class="btn-ghost" bindtap="choosePdf">{{fileInfo ? '重新上传PDF' : '上传财报PDF'}}</view>
      <view class="btn-ghost" bindtap="runAnalyze">开始分析</view>
      <view class="muted" wx:if="{{fileInfo}}">已上传：{{fileInfo.name}}</view>
      <view class="muted" wx:if="{{taskStatus}}">任务状态：{{taskStatus}} {{stage}}</view>
      <view class="line" wx:if="{{resultText}}">{{resultText}}</view>
      <view class="muted" wx:if="{{loading}}">处理中，请稍候...</view>
    </view>

    <view class="card">
      <view class="section-title">下一步（可选）</view>
      <view class="muted">等你确定要接后端时，我会把小程序的上传与任务轮询写好，对应 demo2 的：</view>
      <view class="muted">- /api/upload</view>
      <view class="muted">- /api/analyze</view>
      <view class="muted">- /api/tasks/:taskId</view>
    </view>
  </view>
</view>

