.safe {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 124rpx 24rpx 32rpx;
}

.topbar {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.top-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #0f2f73;
}

.top-sub {
  margin-top: 8rpx;
  display: block;
  font-size: 24rpx;
  color: #64748b;
}

.pill {
  font-size: 22rpx;
  color: #0f2f73;
  background: #e7eefc;
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #e8edf5;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f2f73;
  margin-bottom: 16rpx;
}

.search-input {
  width: 100%;
  height: 78rpx;
  border: 1rpx solid #d9e2ef;
  border-radius: 16rpx;
  background: #f9fbff;
  padding: 0 16rpx;
  box-sizing: border-box;
  font-size: 26rpx;
}

.tabs-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tab-chip {
  font-size: 24rpx;
  color: #475569;
  background: #f1f5f9;
  border-radius: 999rpx;
  padding: 10rpx 20rpx;
}

.tab-chip.active {
  background: #0f2f73;
  color: #fff;
}

.report-row {
  margin-top: 14rpx;
  border: 1rpx solid #e4eaf4;
  border-radius: 18rpx;
  padding: 16rpx;
}

.report-row.selected {
  border-color: #0f2f73;
  background: #f7faff;
}

.report-row-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.report-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.report-date {
  font-size: 22rpx;
  color: #64748b;
}

.report-period {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #334155;
}

.metrics {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.metric {
  font-size: 22rpx;
  color: #0f2f73;
  background: #eef4ff;
  border-radius: 12rpx;
  padding: 6rpx 12rpx;
}

.line {
  font-size: 24rpx;
  line-height: 38rpx;
  color: #344054;
  margin-bottom: 8rpx;
}

.muted {
  font-size: 24rpx;
  color: #667085;
  line-height: 36rpx;
}

.bullet {
  margin-left: 8rpx;
}

.btn-ghost {
  margin-top: 12rpx;
  width: fit-content;
  padding: 14rpx 24rpx;
  border-radius: 14rpx;
  background: #0f2f73;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}

.result-box {
  margin-top: 14rpx;
  background: #f8fafe;
  border: 1rpx solid #dde6f4;
  border-radius: 14rpx;
  padding: 14rpx;
  font-size: 24rpx;
  color: #334155;
  line-height: 1.6;
  white-space: pre-wrap;
}

