/* 整页撑满视口 + 底部输入区贴底（含安全区），避免 flex 内 scroll-view 留白 */
page {
  height: 100%;
  box-sizing: border-box;
}

.chat-page-root {
  height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding-top: calc(env(safe-area-inset-top) + 12rpx);
}

.topbar-chat {
  position: relative;
  flex-shrink: 0;
}

.back-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  border: 2rpx solid #E4E7EC;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  font-size: 32rpx;
  color: #344054;
}

.chat-brand {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  height: 58rpx;
  border-radius: 999rpx;
  background: #FFFFFF;
  border: 2rpx solid #E4E7EC;
  display: flex;
  align-items: center;
  padding: 0 18rpx;
}

.chat-brand-icon { font-size: 28rpx; }
.chat-brand-text {
  margin-left: 8rpx;
  font-size: 24rpx;
  color: #2F54EB;
  font-weight: 700;
}

.chat-page {
  flex: 1;
  min-height: 0;
  padding: 12rpx 20rpx 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.chat-head { display: flex; align-items: center; gap: 10rpx; }
.symbol-input {
  flex: 1;
  height: 64rpx;
  border-radius: 12rpx;
  background: #FFFFFF;
  border: 2rpx solid #E4E7EC;
  padding: 0 16rpx;
  font-size: 24rpx;
}

.symbol-btn {
  width: 134rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: #2F54EB;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stock-chip {
  margin-top: 10rpx;
  margin-bottom: 8rpx;
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  background: #EEF2FF;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.stock-chip-name { font-size: 22rpx; color: #1D2939; font-weight: 600; }
.stock-chip-price { font-size: 24rpx; color: #16A34A; font-weight: 700; }

/* height:0 + flex:1 让 scroll-view 吃掉剩余高度，否则底部会顶不上去 */
.chat-list {
  flex: 1;
  min-height: 0;
  height: 0;
  padding: 8rpx 0 14rpx;
  box-sizing: border-box;
}
.msg-row { display: flex; margin-bottom: 14rpx; padding: 0 6rpx; }
.msg-ai-row { justify-content: flex-start; }
.msg-user-row { justify-content: flex-end; }

.msg-bubble {
  max-width: 82%;
  border-radius: 16rpx;
  padding: 12rpx 14rpx;
}

.msg-ai { background: #F8FAFC; border: 1rpx solid #E4E7EC; }
.msg-user { background: #2F54EB; }
.msg-text { font-size: 24rpx; line-height: 38rpx; color: #101828; }
.msg-user .msg-text { color: #FFFFFF; }

.chat-footer {
  flex-shrink: 0;
  background: #F3F5F8;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  padding-top: 8rpx;
}
.qa-tags { white-space: nowrap; width: 100%; margin-bottom: 10rpx; }
.qa-tags .qa-tag { display: inline-block; white-space: nowrap; }
.qa-tag {
  font-size: 20rpx;
  color: #2F54EB;
  background: #E9EEFF;
  border-radius: 999rpx;
  padding: 8rpx 14rpx;
  margin-right: 10rpx;
}

.ask-row { display: flex; align-items: center; gap: 10rpx; }
.ask-input {
  flex: 1;
  height: 72rpx;
  border-radius: 14rpx;
  background: #FFFFFF;
  border: 2rpx solid #E4E7EC;
  padding: 0 18rpx;
  font-size: 24rpx;
}

.ask-btn {
  width: 108rpx;
  height: 72rpx;
  border-radius: 14rpx;
  background: #2F54EB;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

