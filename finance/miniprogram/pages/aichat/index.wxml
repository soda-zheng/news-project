<view class="safe">
  <view class="topbar">
    <view class="back-btn" bindtap="goBack">←</view>
    <view class="topbar-left">
      <text class="top-title">AI 问答</text>
      <text class="top-sub">股票图形化分析 · 一键进入对话</text>
    </view>
    <text class="pill">分析页</text>
  </view>

  <view class="container">
    <view class="ask-entry" bindtap="goDialog">
      <text class="ask-entry-icon">🤖</text>
      <text class="ask-entry-text">AI智能股票问答</text>
      <text class="ask-entry-arrow">›</text>
    </view>

    <view class="card search-card">
      <input
        class="search-input"
        value="{{keyword}}"
        placeholder="输入股票代码/名称，如 300750 或 宁德时代"
        bindinput="onKeywordInput"
        confirm-type="search"
        bindconfirm="analyzeByInput"
      />
      <view class="search-btn" bindtap="analyzeByInput">分析</view>
    </view>

    <view class="card stock-card">
      <view class="muted" wx:if="{{loading}}">正在拉取实时行情与AI解读...</view>
      <view class="row-between">
        <text class="stock-name">{{current.fullName}}</text>
        <text class="stock-price">{{current.price}}</text>
      </view>
      <text class="stock-info muted">{{current.info}}</text>

      <view class="chart-box">
        <view class="chart-inner">
          <view class="chart-bar b1"></view>
          <view class="chart-bar b2"></view>
          <view class="chart-bar b3"></view>
          <view class="chart-bar b4"></view>
          <view class="chart-bar b5"></view>
        </view>
        <text class="chart-text muted">趋势示意（演示）</text>
      </view>

      <view class="section-title">历史位置</view>
      <view class="kv"><text class="k muted">近1年最高</text><text class="v">{{current.high}}</text></view>
      <view class="kv"><text class="k muted">近1年最低</text><text class="v">{{current.low}}</text></view>
      <view class="kv"><text class="k muted">价格分位</text><text class="v">{{current.level}}</text></view>
      <view class="kv"><text class="k muted">趋势状态</text><text class="v">{{current.trend}}</text></view>
      <view class="kv kv-last"><text class="k muted">近30日波动</text><text class="v">{{current.vol}}</text></view>
    </view>

    <view class="card left-blue">
      <view class="section-title">AI 智能研判</view>
      <view class="line" wx:for="{{current.ai}}" wx:key="*this">- {{item}}</view>
    </view>

    <view class="card left-red">
      <view class="section-title">新闻 & 政策影响</view>
      <view class="line" wx:for="{{current.news}}" wx:key="*this">- {{item}}</view>
    </view>

    <view class="card left-green">
      <view class="section-title">未持仓 · 操作建议</view>
      <view class="line" wx:for="{{current.suggest}}" wx:key="*this">- {{item}}</view>
    </view>

    <view class="disclaimer">AI研判仅供参考，不构成投资建议</view>
  </view>
</view>

