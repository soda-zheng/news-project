.menu-row {
  padding: 16rpx 0;
  border-bottom: 2rpx solid #EEF2F6;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.menu-row:last-child { border-bottom: 0; }
.menu-name { font-size: 26rpx; font-weight: 700; }
.menu-arrow { font-size: 34rpx; }

.line {
  font-size: 24rpx;
  line-height: 38rpx;
  margin-bottom: 8rpx;
}

