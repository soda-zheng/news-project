<view class="safe">
  <view class="topbar">
    <view class="topbar-left">
      <text class="top-title">我的</text>
      <text class="top-sub">设置 · 偏好 · 关于</text>
    </view>
    <text class="pill">简约风</text>
  </view>

  <view class="container">
    <view class="card">
      <view class="section-title">快捷入口</view>
      <view class="menu-row" wx:for="{{profileMenus}}" wx:key="*this" bindtap="tapMenu" data-name="{{item}}">
        <text class="menu-name">{{item}}</text>
        <text class="menu-arrow muted">›</text>
      </view>
    </view>

    <view class="card">
      <view class="section-title">资料融合说明</view>
      <view class="line muted">- 复用 finance 的投研卡片结构与自选交互</view>
      <view class="line muted">- 参考 demo2 的热点榜字段（name/leader/pct_chg）</view>
      <view class="line muted">- 参考 demo2 的首页新闻字段（title/category/summary）</view>
    </view>
  </view>
</view>

