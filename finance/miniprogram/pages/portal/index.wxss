.app-container {
  max-width: 750rpx;
  margin: 0 auto;
  background: #f5f7fb;
  min-height: 100vh;
  position: relative;
  box-sizing: border-box;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* AI 问答：上方浅灰底，底部单独白底输入区 */
.app-container.app-chat-mode {
  padding-bottom: 0;
  background: #f5f7fb;
  min-height: 100vh;
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.page {
  display: none;
  padding: 32rpx;
  animation: fadeIn 0.25s ease;
}

.page.active-page {
  display: block;
}

.page.page-chat {
  padding: 0;
  animation: none;
}

.page.page-chat.active-page {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

/* 自选页略减顶内边距，由 watchlist-header-row 动态 margin-top 避让胶囊菜单 */
.page.page-watchlist {
  padding-top: 24rpx;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  max-width: 750rpx;
  margin: 0 auto;
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 20rpx 16rpx calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
  z-index: 20;
  box-sizing: border-box;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.tab-text {
  font-size: 20rpx;
  color: #8e9aaf;
  font-weight: 500;
}

.tab-item.active .tab-text {
  color: #0f2f73;
}

.tab-icon {
  font-size: 44rpx;
}

.card {
  background: #ffffff;
  border-radius: 48rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
  border: 1rpx solid rgba(0, 0, 0, 0.03);
}

.welcome-section {
  margin-bottom: 40rpx;
}

.hello-text {
  font-size: 56rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #0f2f73, #1e4a8a);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.ai-chat-entry {
  background: linear-gradient(135deg, #0f2f73, #1e4a8a);
  border-radius: 56rpx;
  padding: 32rpx 40rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.ai-chat-entry:active {
  opacity: 0.95;
}

.ai-chat-entry-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.ai-chat-icon {
  width: 96rpx;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.ai-chat-text {
  display: flex;
