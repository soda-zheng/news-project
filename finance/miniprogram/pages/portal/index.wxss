  border-top: 1rpx solid #edf2f7;
}

.chat-full-page {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  background: #f5f7fb;
  border-radius: 0;
  overflow: hidden;
}

.chat-full-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx 32rpx;
  background: #ffffff;
  border-bottom: none;
  box-sizing: border-box;
}

.chat-header-side {
  width: 72rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.chat-header-spacer {
  visibility: hidden;
}

.chat-back {
  font-size: 44rpx;
  font-weight: 600;
  color: #0f2f73;
  line-height: 1;
}

.chat-header-title {
  flex: 1;
  text-align: center;
  font-weight: 700;
  font-size: 38rpx;
  color: #0f2f73;
}

.chat-full-messages {
  width: 100%;
  flex-shrink: 0;
  padding: 28rpx 24rpx 20rpx;
  background: #f5f7fb;
  box-sizing: border-box;
}

.message {
  margin-bottom: 32rpx;
  display: flex;
  flex-direction: column;
}

.user-msg {
  align-items: flex-end;
}

.ai-msg {
  align-items: flex-start;
}

.bubble {
  max-width: 92%;
  padding: 28rpx 36rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
  line-height: 1.55;
}

.user-msg .bubble {
  background: #0f2f73;
  color: #fff;
}

.ai-msg .bubble {
  background: #fff;
  color: #1e293b;
  box-shadow: 0 4rpx 24rpx rgba(15, 47, 115, 0.08);
  border: 0.5rpx solid rgba(0, 0, 0, 0.04);
}

.bubble-press {
  opacity: 0.88;
}

.chat-input-wrap {
  flex-shrink: 0;
  width: 100%;
  background: #ffffff;
  border-top: none;
  border-radius: 48rpx 48rpx 0 0;
  box-shadow: 0 -8rpx 40rpx rgba(15, 23, 42, 0.07);
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}

.chat-full-input {
  display: flex;
  gap: 20rpx;
  align-items: center;
  padding: 36rpx 32rpx 40rpx;
  background: #ffffff;
  border-radius: 48rpx 48rpx 0 0;
  box-sizing: border-box;
}

.chat-input {
  flex: 1;
  min-width: 0;
  min-height: 96rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 999rpx;
  padding: 24rpx 36rpx;
  font-size: 30rpx;
  line-height: 1.45;
  background: #fff;
  box-sizing: border-box;
  color: #1e293b;
}

/* 点击聚焦后：黑色描边，与参考图一致 */
.chat-input.chat-input--focus {
  border-color: #0f172a;
  border-width: 2rpx;
}

.chat-input-ph {
  color: #64748b;
}

.chat-send-btn {
  min-width: 128rpx;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0 32rpx;
  border-radius: 999rpx;
  background: #102c6d;
  color: #fff;
  font-weight: 600;
  font-size: 28rpx;
  text-align: center;
  flex-shrink: 0;
  box-sizing: border-box;
}

/* 按下态：底色明显变深 + 轻微缩小，比单纯 opacity 更易感知 */
.chat-send-btn.chat-send-press {
  background: #0a1f50;
  transform: scale(0.96);
  opacity: 1;
}

.watchlist-header-row {
