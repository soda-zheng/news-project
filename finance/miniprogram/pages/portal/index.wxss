page {
  height: 100%;
  background: #f5f7fb;
}

.app-container {
  max-width: 750rpx;
  margin: 0 auto;
  background: #f5f7fb;
  min-height: 100vh;
  position: relative;
  box-sizing: border-box;
  padding-bottom: calc(148rpx + env(safe-area-inset-bottom));
}

