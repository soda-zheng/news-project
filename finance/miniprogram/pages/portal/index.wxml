<view class="app-container theme-{{uiTheme}} {{activePage === 'chat' ? 'app-chat-mode' : ''}}" style="padding-top: {{statusBarHeight}}px;">
  <view class="page {{activePage === 'home' ? 'active-page' : ''}}">
    <view class="welcome-section">
      <view class="hello-text">你好，投资者</view>
    </view>
    <view class="ai-chat-entry" bindtap="onAiChatEntry">
      <view class="ai-chat-entry-left">
        <view class="ai-chat-icon">🤖</view>
        <view class="ai-chat-text">
          <text class="ai-chat-h4">AI 智能助手</text>
          <text class="ai-chat-p">股票分析 · 一键进入对话</text>
        </view>
      </view>
      <text class="ai-chat-arrow">→</text>
    </view>
    <view class="card news-home-card">
      <view class="hot-header">
        <text class="hot-tag">🔥 热点报道</text>
        <text class="more-link">精选价值资讯</text>
      </view>
      <view class="news-scope-tabs">
        <view
          class="news-scope-tab {{homeNewsRegion === 'all' ? 'active' : ''}}"
          data-region="all"
          bindtap="onHomeNewsScopeTap"
        >全部</view>
        <view
          class="news-scope-tab {{homeNewsRegion === 'domestic' ? 'active' : ''}}"
          data-region="domestic"
          bindtap="onHomeNewsScopeTap"
        >国内</view>
        <view
          class="news-scope-tab {{homeNewsRegion === 'global' ? 'active' : ''}}"
          data-region="global"
          bindtap="onHomeNewsScopeTap"
        >国际</view>
      </view>
      <view wx:if="{{_homeNewsLoading}}" class="news-loading-hint">加载中…</view>
      <view
        class="news-item"
        wx:for="{{homeNewsList}}"
        wx:key="id"
        data-newsid="{{item.id}}"
        data-url="{{item.url}}"
        bindtap="onNewsTap"
      >
        <view
          wx:if="{{item.regionLabel}}"
          class="news-region-pill {{item.region === 'global' ? 'is-global' : ''}} {{item.region === 'both' ? 'is-both' : ''}}"
        >{{item.regionLabel}}</view>
        <view class="news-title">{{item.title}}</view>
        <view class="news-ai-summary">{{item.summary}}</view>
        <view class="news-meta">
          <text>{{item.metaTime}}</text>
          <text>{{item.metaSource}}</text>
        </view>
        <view class="stock-chips">
          <text class="stock-chip" wx:for="{{item.chips}}" wx:for-item="chip" wx:key="*this">{{chip}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="page {{activePage === 'topic' ? 'active-page' : ''}}">
    <view class="topic-nav">
      <view class="back-btn" bindtap="onBackTopic">←</view>
      <text class="topic-nav-title">话题精读</text>
    </view>
    <block wx:if="{{topicDetail}}">
      <view class="topic-header">
        <view class="topic-title">{{topicDetail.title}}</view>
      </view>

      <view class="card causal-card" wx:if="{{topicDetail.causalChain && topicDetail.causalChain.length}}">
        <view class="section-label section-label-inline">🔗 因果链</view>
        <view class="causal-flow">
          <block wx:for="{{topicDetail.causalChain}}" wx:key="label" wx:for-index="idx">
            <view class="causal-box">
              <text class="causal-tag">{{item.label}}</text>
              <text class="causal-box-body">{{item.text}}</text>
            </view>
            <view class="causal-arrow-down" wx:if="{{idx < topicDetail.causalChain.length - 1}}">↓</view>
          </block>
        </view>
      </view>

      <view class="drive-card">
        <view class="section-label">📌 驱动事件</view>
        <view class="drive-text">{{topicDetail.drive}}</view>
      </view>
      <view class="logic-card">
        <view class="section-label">💡 投资逻辑</view>
        <view class="drive-text">{{topicDetail.logic}}</view>
      </view>

      <view class="card timeline-card" wx:if="{{topicDetail.timeline && topicDetail.timeline.length}}">
        <view class="section-label section-label-inline">📅 关键时间轴 / 跟踪点</view>
        <view class="mini-timeline">
          <view class="tl-row" wx:for="{{topicDetail.timeline}}" wx:key="date">
            <text class="tl-date">{{item.date}}</text>
            <text class="tl-desc">{{item.title}}<text wx:if="{{item.tag}}" class="tl-tag"> · {{item.tag}}</text></text>
          </view>
        </view>
      </view>

      <view class="card">
        <view class="core-title">📊 核心标的</view>
        <view class="stock-row" wx:for="{{topicDetail.stocks}}" wx:key="code">
          <view>
            <text class="stock-name-inline">{{item.name}}</text>
            <text class="text-small"> {{item.code}}</text>
          </view>
          <text class="stock-change {{item.positive ? '' : 'negative'}}">{{item.change}}</text>
        </view>
      </view>
      <view class="news-original" bindtap="onOpenStockNews" data-url="{{topicDetail.url}}">
        <view class="news-original-title">📰 新闻原文 <text class="news-original-link">点击查看 ></text></view>
        <view class="news-original-content">{{topicDetail.originalNews}}</view>
      </view>

      <view class="topic-notes-card">
        <view class="section-label">📝 我的笔记（仅本机）</view>
        <textarea
          class="topic-note-textarea"
          value="{{topicNoteBody}}"
          placeholder="记录你的判断、存疑点或验证计划…"
          maxlength="2000"
          bindinput="onTopicNoteBodyInput"
        />
        <view class="topic-actions">
          <view class="btn-primary-sm" bindtap="saveTopicTextNote">保存笔记</view>
          <view class="btn-secondary-sm" bindtap="addTopicToWatchlist">加入观察清单</view>
        </view>
        <view class="topic-note-saved text-small" wx:if="{{topicNoteSaved}}">上次保存：{{topicNoteSaved}}</view>
      </view>
    </block>
  </view>

  <view class="page {{activePage === 'stock' ? 'active-page' : ''}}">
    <view class="section-title">📈 个股分析</view>
    <view class="search-box">
      <view class="search-input" bindtap="openStockPicker">{{stockSearchInput || '代码或名称，如 600519、宁德时代'}}</view>
      <view class="search-btn" bindtap="openStockPicker">选股</view>
    </view>
    <view class="stock-suggest-wrap" wx:if="{{stockSuggestLoading || stockSuggestList.length}}">
      <view wx:if="{{stockSuggestLoading}}" class="stock-suggest-status">正在匹配全市场 A 股…</view>
      <scroll-view wx:elif="{{stockSuggestList.length}}" scroll-y class="stock-suggest-scroll">
        <view class="stock-suggest-row" wx:for="{{stockSuggestList}}" wx:key="code" data-code="{{item.code}}" bindtap="onPickStockSuggest">
          <text class="stock-suggest-name">{{item.name}}</text>
          <text class="stock-suggest-code">{{item.code}}</text>
        </view>
      </scroll-view>
    </view>
    <view class="stock-info-card">
      <view class="stock-name-row">
        <text class="stock-name-lg">{{stockName}}</text>
        <text class="stock-code-lg">{{stockCode}}</text>
      </view>
      <view class="price-row">
        <text class="stock-price-lg">{{stockPrice}}</text>
        <text class="stock-change-percent {{stockChangePositive ? 'positive' : 'negative'}}">{{stockChange}}</text>
      </view>
      <view class="stock-detail">{{stockDetail}}</view>
      <view class="position-meter">
        <view class="position-meter-label">
          <text>近1年价格分位（可视化）</text>
          <text>{{percentileLabel}}</text>
        </view>
        <view class="position-meter-track">
          <view class="position-meter-marker" style="left: {{percentileMarkerLeft}}%;"></view>
        </view>
        <view class="position-meter-scale">
          <text>历史偏低</text>
          <text>历史偏高</text>
        </view>
        <view class="percentile-def-hint" wx:if="{{percentileDefHint}}">{{percentileDefHint}}</view>
      </view>
    </view>
    <view class="stock-quick-row">
      <view
        wx:if="{{stockQuickQuestions && stockQuickQuestions.length}}"
      >
        <view
          style="margin-bottom: 0;"
          wx:for="{{stockQuickQuestions}}"
          wx:key="*this"
          data-q="{{item}}"
          bindtap="onStockQuickAsk"
        >
          <view class="stock-quick-btn">{{item}}</view>
        </view>
      </view>
      <view wx:else>
        <view class="stock-quick-btn" data-q="结合当前分位与10/20日动量，下一步走势更偏哪边？" bindtap="onStockQuickAsk">走势动量追问</view>
        <view class="stock-quick-btn" data-q="52周回撤下，最该盯的支撑/压力信号是什么？" bindtap="onStockQuickAsk">支撑压力信号</view>
        <view class="stock-quick-btn" data-q="若继续偏弱，未持仓者如何控风险与等信号？" bindtap="onStockQuickAsk">偏弱风险控法</view>
      </view>
    </view>

    <view class="kline-container">
      <view class="kline-header">
        <text class="kline-title">📈 K线走势图</text>
        <view class="kline-btn" bindtap="onResetKline">最新</view>
      </view>
      <view class="kline-canvas-wrap">
        <view wx:if="{{!klineShowEcharts}}" class="kline-placeholder">{{klinePlaceholderText}}</view>
        <view
          wx:if="{{klineShowEcharts}}"
          class="kline-ec-host"
          bindtouchstart="onKlineTouchStart"
          bindtouchmove="onKlineTouchMove"
        >
          <!-- 自绘 K 线（DOM 方式）：不依赖 canvas/eCharts，彻底杜绝"跟着鼠标走/两层溢出" -->
          <view class="kline-dom-grid">
            <view
              wx:for="{{klineDomPriceMarks}}"
              wx:key="topPct"
              class="kline-dom-grid-line"
              style="top: {{item.topPct}}%;"
            ></view>
          </view>
          <view wx:if="{{klineDomPriceMarks && klineDomPriceMarks.length}}" class="kline-dom-axis">
            <view
              wx:for="{{klineDomPriceMarks}}"
              wx:key="*this"
              class="kline-dom-axis-item"
              style="top: {{item.topPct}}%;"
            >
              {{item.text}}
            </view>
          </view>
          <view class="kline-dom-price">
            <view class="kline-dom-row kline-dom-price-row">
              <view
                wx:for="{{klineDomCandles}}"
                wx:key="idx"
                class="kline-dom-candle"
                style="width: {{klineDomCandleWidthPct}}%;"
              >
                <view
                  class="kline-dom-wick"
                  style="width: {{item.wickWidthPct}}%; top: {{item.wickTopPct}}%; height: {{item.wickHeightPct}}%; background-color: {{item.color}};"
                ></view>
                <view
                  class="kline-dom-body"
                  style="width: {{item.bodyWidthPct}}%; top: {{item.bodyTopPct}}%; height: {{item.bodyHeightPct}}%; background-color: {{item.color}};"
                ></view>
              </view>
            </view>
          </view>

          <view wx:if="{{klineDomDateLabels && klineDomDateLabels.length}}" class="kline-dom-dates-row">
            <view
              wx:for="{{klineDomDateLabels}}"
              wx:key="*this"
              class="kline-dom-date"
            >{{item}}</view>
          </view>
        </view>
      </view>
      <view class="kline-tip">红=收盘高于开盘，绿=收盘低于开盘；蜡烛长短表示涨跌强弱，影线表示最高/最低；拖动放大/缩小看更近或更远</view>
    </view>
    <view class="history-card">
      <view class="history-title">📊 历史位置</view>
      <view class="history-grid">
        <view class="history-item">
          <view class="history-label">近1年最高</view>
          <view class="history-value">{{high52w}}</view>
        </view>
        <view class="history-item">
          <view class="history-label">近1年最低</view>
          <view class="history-value">{{low52w}}</view>
        </view>
        <view class="history-item">
          <view class="history-label">价格分位</view>
          <view class="history-value">{{percentileText}} <text class="history-sub">{{percentileSub}}</text></view>
        </view>
        <view class="history-item">
          <view class="history-label">趋势状态</view>
          <view class="history-value">{{trendText}}</view>
        </view>
      </view>
      <view class="text-small history-vol-line">近30日波动：<text>{{volText}}</text></view>
    </view>
    <view class="ai-insight-card">
      <view class="insight-title">🤖 AI 智能研判</view>
      <view class="insight-li" wx:for="{{aiInsightList}}" wx:key="*this">• {{item}}</view>
    </view>
    <view class="suggestion-card">
      <view class="suggestion-title">📌 未持仓 · 操作建议</view>
      <view class="insight-li" wx:for="{{suggestionList}}" wx:key="*this">• {{item}}</view>
      <view class="disclaimer">AI研判仅供参考，不构成投资建议</view>
    </view>

    <!-- 📰 个股相关新闻 - 放在页面最底部 -->
    <view class="card stock-news-card" wx:if="{{stockNewsList && stockNewsList.length}}">
      <view class="section-title">📰 相关新闻</view>
      <view class="stock-news-list">
        <view class="stock-news-item" wx:for="{{stockNewsList}}" wx:key="title" bindtap="onOpenStockNews" data-url="{{item.url}}" data-title="{{item.title}}">
          <view class="stock-news-title">{{item.title}}</view>
          <view class="stock-news-meta">
            <text class="stock-news-source">{{item.source}}</text>
            <text class="stock-news-time" wx:if="{{item.ctimeStr}}">{{item.ctimeStr}}</text>
          </view>
          <view class="stock-news-link">点击查看原文 ></view>
        </view>
      </view>
    </view>
  </view>

  <view class="page page-chat {{activePage === 'chat' ? 'active-page' : ''}}">
    <view class="chat-full-page">
      <view class="chat-full-header">
        <view class="chat-header-side">
          <view class="back-btn chat-back" bindtap="onBackChat">←</view>
        </view>
        <text class="chat-header-title">AI 智能问答</text>
        <view class="chat-header-side chat-header-spacer"></view>
      </view>
      <scroll-view class="chat-full-messages" scroll-y scroll-into-view="{{chatScrollToId}}">
        <view wx:for="{{chatMessages}}" wx:key="index" id="msg-{{index}}" class="message {{item.role === 'user' ? 'user-msg' : 'ai-msg'}}">
          <view class="bubble" hover-class="bubble-press" hover-stay-time="80">{{item.text}}</view>
        </view>
      </scroll-view>
      <!-- 底栏整块白底贴屏底，安全区内边距只在这一层，避免输入条下方再露一截异色 -->
      <view class="chat-footer-dock">
        <view class="chat-chips-wrap">
          <view
            class="chat-chip"
            wx:for="{{chatQuickChips}}"
            wx:key="label"
            data-q="{{item.q}}"
            bindtap="onChatChipTap"
          >{{item.label}}</view>
        </view>
        <view class="chat-full-input">
          <input
            class="chat-input {{chatInputFocus ? 'chat-input--focus' : ''}}"
            value="{{chatInput}}"
            focus="{{chatInputFocus}}"
            placeholder="输入问题，与AI对话..."
            placeholder-class="chat-input-ph"
            bindtap="onChatInputTap"
            bindinput="onChatInput"
            bindfocus="onChatInputFocus"
            bindblur="onChatInputBlur"
            confirm-type="send"
            bindconfirm="onSendChat"
            cursor-spacing="24"
            adjust-position="{{true}}"
          />
          <view
            class="chat-send-btn"
            hover-class="chat-send-press"
            hover-start-time="0"
            hover-stay-time="200"
            bindtap="onSendChat"
          >发送</view>
        </view>
      </view>
    </view>
  </view>

  <view class="page page-watchlist {{activePage === 'watchlist' ? 'active-page' : ''}}">
    <view class="watchlist-header-row" style="margin-top: {{watchlistHeaderMarginTopPx}}px;">
      <view class="section-title watchlist-section-title">⭐ 我的观察清单</view>
      <view
        class="watchlist-add-btn"
        hover-class="watchlist-add-btn-press"
        hover-start-time="0"
        hover-stay-time="120"
        bindtap="openWatchlistAdd"
      >+ 添加</view>
    </view>
    <view class="card">
      <block wx:if="{{watchlistItems.length}}">
        <view class="watchlist-item" wx:for="{{watchlistItems}}" wx:key="code">
          <view class="watchlist-item-main" data-code="{{item.code}}" bindtap="onWatchItemTap">
            <view><text class="wl-strong">{{item.name}}</text><text class="text-small"> {{item.labelCode}}</text></view>
            <text class="stock-change-percent watchlist-pct {{item.changeStr == '--' ? 'neutral' : (item.positive ? 'positive' : 'negative')}}">{{item.changeStr}}</text>
          </view>
          <view
            class="watchlist-remove-btn"
            hover-class="watchlist-remove-btn-hover"
            catchtap="onRemoveWatchlistItem"
            data-code="{{item.code}}"
          >移除</view>
        </view>
      </block>
      <view wx:else class="watchlist-empty-hint">暂无标的，可在「话题精读」中点击加入观察清单，或点右上角添加。</view>
    </view>
    <view wx:if="{{watchlistAddVisible}}" class="watchlist-modal-mask" catchtouchmove="stopBubble" bindtap="closeWatchlistAdd">
      <view class="watchlist-modal" catchtap="stopBubble">
        <view class="watchlist-modal-title">添加自选股</view>
        <input
          class="watchlist-modal-input"
          placeholder="代码或名称，如 600519、贵州茅台"
          placeholder-class="watchlist-modal-ph"
          value="{{watchlistAddInput}}"
          bindinput="onWatchlistAddInput"
          confirm-type="done"
          bindconfirm="confirmWatchlistAdd"
          adjust-position="{{true}}"
        />
        <view class="watchlist-modal-actions">
          <view class="watchlist-modal-btn cancel" bindtap="closeWatchlistAdd">取消</view>
          <view class="watchlist-modal-btn ok" bindtap="confirmWatchlistAdd">确定</view>
        </view>
      </view>
    </view>
  </view>

  <view class="page {{activePage === 'earnings' ? 'active-page' : ''}}">
    <view class="section-title">📄 AI 财报尽调</view>
    <view class="upload-area" bindtap="onUploadAreaTap">
      <view class="upload-icon">📂</view>
      <view>点击上传财报文件</view>
      <view class="text-small">支持 PDF（小程序内从聊天选择文件；完整解析可对接后端）</view>
    </view>
    <view wx:if="{{earningsVisible}}" class="analysis-result">
      <view class="earnings-section-title">📋 财报任务状态</view>
      <view class="text-small earnings-file-line" wx:if="{{earningsFileName}}">📄 文件：{{earningsFileName}}</view>
      <view class="text-small earnings-file-line" wx:if="{{earningsTaskStatus}}">状态：{{earningsTaskStatus}} {{earningsStage}}</view>
      <view class="text-small earnings-file-line" wx:if="{{earningsLoading}}">处理中，请稍候...</view>

      <view class="earnings-section-title earnings-ai-title">🤖 AI 综合解读</view>
      <view class="earnings-analysis-block">{{earningsHtml || '等待解析结果...'}}</view>

      <view class="earnings-faq-block" wx:if="{{earningsPages.length}}">
        <view class="earnings-faq-title">逐题解析</view>
        <view class="earnings-pager-meta">
          <text class="earnings-pager-tip">第 <text class="earnings-pager-num">{{earningsPageIndex + 1}}</text> / <text class="earnings-pager-num">{{earningsPages.length}}</text> 题</text>
          <view class="earnings-edit-btn" bindtap="openEarningsEdit">编辑本题</view>
        </view>
        <view class="earnings-analysis-content">
          <block wx:for="{{earningsPageBlocks}}" wx:key="index">
            <view wx:if="{{item.type === 'h3'}}" class="earnings-ac-h3">{{item.text}}</view>
            <view wx:if="{{item.type === 'sec'}}" class="earnings-ac-sec">{{item.text}}</view>
            <view
              wx:if="{{item.type === 'p'}}"
              class="earnings-ac-p {{(index > 0 && earningsPageBlocks[index-1].type === 'sec' && earningsPageBlocks[index-1].text === '核心结论：') ? 'earnings-core-box' : ''}}"
            >{{item.text}}</view>
            <view wx:if="{{item.type === 'ul'}}" class="earnings-ac-ul">
              <view class="earnings-ac-li" wx:for="{{item.items}}" wx:for-item="li" wx:key="*this">{{li}}</view>
            </view>
          </block>
        </view>
        <view class="earnings-pager-row">
          <view class="earnings-pager-btn {{earningsPageIndex <= 0 ? 'disabled' : ''}}" bindtap="onEarningsPagePrev">← 上一题</view>
          <view class="earnings-pager-btn {{earningsPageIndex >= earningsPages.length - 1 ? 'disabled' : ''}}" bindtap="onEarningsPageNext">下一题 →</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{earningsEditVisible}}" class="earnings-edit-mask" catchtouchmove="stopBubble" bindtap="closeEarningsEdit">
    <view class="earnings-edit-modal" catchtap="stopBubble">
      <view class="earnings-edit-title">编辑当前题目（仅重生成本题）</view>
      <view class="earnings-edit-label">自定义问题（可选）</view>
      <input
        class="earnings-edit-input"
        value="{{earningsEditQuestion}}"
        placeholder="例如：本期毛利率提升主要来自结构还是成本？"
        bindinput="onEarningsEditQuestionInput"
      />
      <view class="earnings-edit-label">换一个数据点（可选）</view>
      <picker mode="selector" range="{{earningsFactChoices}}" value="{{earningsEditChoiceIndex}}" bindchange="onEarningsEditChoiceChange">
        <view class="earnings-edit-picker">{{earningsFactChoices.length ? (earningsFactChoices[earningsEditChoiceIndex] || '选择一个数据点') : '暂无数据点（先生成解析）'}}</view>
      </picker>
      <view class="earnings-edit-hint text-small">仅选数据点、不填上方问题时，会自动生成一道分析问句（不再把「指标｜数值｜页码」当标题）。</view>
      <view class="earnings-edit-actions">
        <view class="earnings-edit-btn2 cancel" bindtap="closeEarningsEdit">取消</view>
        <view class="earnings-edit-btn2 ok {{earningsEditBusy ? 'disabled' : ''}}" bindtap="saveEarningsEdit">保存并重算</view>
      </view>
    </view>
  </view>

  <view class="page {{activePage === 'mine' ? 'active-page' : ''}}">
    <view class="section-title mine-title">👤 我的</view>
    <view class="card" wx:if="{{profileUser}}">
      <view class="mine-user-row">
        <image class="mine-avatar" src="{{profileUser.avatarUrl}}" mode="aspectFill" />
        <view class="mine-user-meta">
          <text class="mine-nick">{{profileUser.nickName}}</text>
          <text class="text-small muted">与启动页微信登录为同一账号</text>
        </view>
      </view>
    </view>
    <view class="card" wx:else>
      <view class="mine-tip text-small">尚未微信登录：自选暂存在本机「游客」空间，登录后与账号绑定。</view>
      <view class="mine-login-btn" bindtap="goIndexLogin">去启动页登录</view>
    </view>
    <view class="card mine-watch-entry" bindtap="onMineWatchlistTap">
      <view class="mine-watch-entry-top">
        <text class="core-title mine-watch-title">⭐ 我的自选</text>
        <text class="menu-arrow muted">›</text>
      </view>
      <text class="text-small muted" wx:if="{{watchlistCount > 0}}">共 {{watchlistCount}} 只</text>
    </view>
    <view class="card">
      <view class="core-title">快捷入口</view>
      <view class="menu-row" wx:for="{{profileMenus}}" wx:key="*this" bindtap="tapMenu" data-name="{{item}}">
        <text class="menu-name">{{item}}</text>
        <text class="menu-arrow muted">›</text>
      </view>
    </view>
    <view class="card" wx:if="{{profileUser}}">
      <view class="menu-row" bindtap="onLogoutTap">
        <text class="menu-name mine-logout">退出登录</text>
        <text class="menu-arrow muted">›</text>
      </view>
      <view class="text-small muted mine-logout-hint">退出后清除微信头像昵称；自选仍保留在本机同一账号空间中。</view>
    </view>
  </view>

  <view class="tab-bar" wx:if="{{activePage !== 'chat'}}">
    <view class="tab-item {{tabSelected === 'home' ? 'active' : ''}}" data-page="home" bindtap="onTabTap">
      <text class="tab-icon">🏠</text>
      <text class="tab-text">首页</text>
    </view>
    <view class="tab-item {{tabSelected === 'stock' ? 'active' : ''}}" data-page="stock" bindtap="onTabTap">
      <text class="tab-icon">📊</text>
      <text class="tab-text">个股分析</text>
    </view>
    <view class="tab-item {{tabSelected === 'watchlist' ? 'active' : ''}}" data-page="watchlist" bindtap="onTabTap">
      <text class="tab-icon">⭐</text>
      <text class="tab-text">自选</text>
    </view>
    <view class="tab-item {{tabSelected === 'earnings' ? 'active' : ''}}" data-page="earnings" bindtap="onTabTap">
      <text class="tab-icon">📄</text>
      <text class="tab-text">财报</text>
    </view>
    <view class="tab-item {{tabSelected === 'mine' ? 'active' : ''}}" data-page="mine" bindtap="onTabTap">
      <text class="tab-icon">👤</text>
      <text class="tab-text">我的</text>
    </view>
  </view>
</view>
