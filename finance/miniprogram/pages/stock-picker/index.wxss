.picker-page {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 28rpx;
  /* 顶部安全区补偿：避免内容在真机/刘海屏上“偏上过高” */
  padding-top: calc(28rpx + env(safe-area-inset-top) + 128rpx);
  box-sizing: border-box;
}

/* 深色模式（跟随 portal 的主题设置） */
.picker-page.theme-dark {
  background: #0b1220;
}
.picker-page.theme-dark .picker-title,
.picker-page.theme-dark .picker-back,
.picker-page.theme-dark .picker-section-title,
.picker-page.theme-dark .picker-name {
  color: #e5e7eb;
}
.picker-page.theme-dark .picker-input {
  background: rgba(15, 23, 42, 0.92);
  border-color: rgba(148, 163, 184, 0.2);
  color: rgba(226, 232, 240, 0.9);
}
.picker-page.theme-dark .picker-btn {
  background: rgba(15, 47, 115, 0.62);
  color: #e5e7eb;
}
.picker-page.theme-dark .picker-section {
  background: rgba(15, 23, 42, 0.92);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
}
.picker-page.theme-dark .history-chip {
  background: rgba(148, 163, 184, 0.14);
  color: rgba(226, 232, 240, 0.86);
}
.picker-page.theme-dark .picker-status,
.picker-page.theme-dark .picker-code {
  color: rgba(226, 232, 240, 0.62);
}
.picker-page.theme-dark .picker-row {
  border-bottom-color: rgba(148, 163, 184, 0.16);
}
.picker-page.theme-dark .picker-row.active .picker-name,
.picker-page.theme-dark .picker-row.active .picker-code {
  color: #e5e7eb;
}
.picker-page.theme-dark .picker-rank {
  background: rgba(251, 146, 60, 0.2);
  color: #fdba74;
}

.picker-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.picker-back {
  width: 56rpx;
  color: #0f2f73;
  font-size: 40rpx;
}

.picker-back.ghost {
  opacity: 0;
}

.picker-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f2f73;
}

.picker-search-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.picker-input {
  flex: 1;
  height: 84rpx;
  background: #fff;
  border-radius: 18rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 1rpx solid #e8edf5;
}

.picker-btn {
  width: 140rpx;
  height: 84rpx;
  border-radius: 18rpx;
  background: #0f2f73;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.picker-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.history-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.history-chip {
  background: #f2f5fb;
  color: #35435c;
  border-radius: 14rpx;
  padding: 10rpx 18rpx;
  font-size: 24rpx;
}

.picker-section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f2f73;
  margin-bottom: 16rpx;
}

.picker-hint {
  font-size: 22rpx;
  color: #8a95a8;
  line-height: 1.45;
  margin: -8rpx 0 12rpx;
}

.picker-status {
  font-size: 24rpx;
  color: #8a95a8;
  padding: 12rpx 0;
}

.picker-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eef1f6;
}

.picker-row:last-child {
  border-bottom: 0;
}

.picker-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.picker-rank {
  width: 34rpx;
  height: 34rpx;
  border-radius: 10rpx;
  background: #ffefe1;
  color: #de6b13;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.picker-row.active .picker-name,
.picker-row.active .picker-code {
  color: #0f2f73;
  font-weight: 700;
}

.picker-name {
  font-size: 28rpx;
  color: #1f2937;
}

.picker-right {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.picker-code {
  font-size: 24rpx;
  color: #73829b;
}

.picker-pct {
  font-size: 24rpx;
  min-width: 90rpx;
  text-align: right;
}

.picker-pct.up {
  color: #ef4444;
}

.picker-pct.down {
  color: #22c55e;
}
