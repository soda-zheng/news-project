.safe {
  padding-top: 128rpx;
}

.add-watch {
  text-align: center;
  color: #2F54EB;
  background: #EEF2FF;
  font-size: 26rpx;
  font-weight: 700;
}

.watch-item {
  background: #FFFFFF;
  border-radius: 22rpx;
  padding: 22rpx;
  margin-bottom: 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.watch-name { font-size: 28rpx; font-weight: 800; }
.watch-code { margin-top: 6rpx; font-size: 22rpx; }
.watch-right { display: flex; flex-direction: column; align-items: flex-end; }
.watch-price { font-size: 32rpx; font-weight: 900; color: #16A34A; }
.watch-tip { margin-top: 6rpx; font-size: 22rpx; }

